# Copy this file to `.env` and fill in only the values you want to use.
# Never commit real API keys to the repository.

# Remote answer generation
GENERATION_PROVIDER=openrouter
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# If OpenAI does not work for you, use OpenRouter instead.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=multimodal-rag-colpali

# Retrieval model (Hugging Face model ID or a local checkpoint path)
COLPALI_MODEL=vidore/colpali-v1.3

# Force TF-IDF-only mode (skip ColPali entirely). Useful when Hugging Face is unreachable.
# Set to 'true' to enable. Default: false (tries ColPali first, falls back to TF-IDF if needed)
USE_TFIDF_ONLY=false

# Optional index and data paths (defaults shown)
DATA_DIR=./data
INDEX_DIR=./index

# Optional retrieval settings
TOP_K_PAGES=3
MAX_ANSWER_TOKENS=600
